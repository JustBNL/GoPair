<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gopair.voiceservice.mapper.VoiceCallParticipantMapper">

    <delete id="deleteByCallIds">
        DELETE FROM voice_call_participant WHERE call_id IN
        <foreach collection="callIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
