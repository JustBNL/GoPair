        <!-- 分页插件 -->
        <plugin interceptor="com.baomidou.mybatisplus.extension.plugins.MybatisPlusInterceptor">
            <property name="innerInterceptors" value="com.baomidou.mybatisplus.extension.plugins.inner.PaginationInnerInterceptor"/>
        </plugin>
    </plugins>
</configuration> 