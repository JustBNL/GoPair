<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gopair.fileservice.mapper.RoomFileMapper">

    <!-- 结果映射 -->
    <resultMap id="RoomFileResultMap" type="com.gopair.fileservice.domain.po.RoomFile">
        <id column="file_id" property="fileId"/>
        <result column="room_id" property="roomId"/>
        <result column="uploader_id" property="uploaderId"/>
        <result column="uploader_nickname" property="uploaderNickname"/>
        <result column="file_name" property="fileName"/>
        <result column="file_path" property="filePath"/>
        <result column="file_size" property="fileSize"/>
        <result column="thumbnail_size" property="thumbnailSize"/>
        <result column="file_type" property="fileType"/>
        <result column="content_type" property="contentType"/>
        <result column="download_count" property="downloadCount"/>
        <result column="upload_time" property="uploadTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 通用列 -->
    <sql id="Base_Column_List">
        file_id, room_id, uploader_id, uploader_nickname, file_name, file_path,
        file_size, thumbnail_size, file_type, content_type, download_count,
        upload_time, create_time, update_time
    </sql>

    <!-- 动态分页查询房间文件列表（支持搜索、类型筛选、排序） -->
    <select id="selectPage" resultMap="RoomFileResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM room_file
        <where>
            <if test="roomId != null">
                AND room_id = #{roomId}
            </if>
            <!-- 关键字搜索：模糊匹配文件名 -->
            <if test="keyword != null and keyword != ''">
                AND file_name LIKE CONCAT('%', #{keyword}, '%')
            </if>
            <!-- 文件类型筛选：通过业务分类映射到扩展名 IN 条件 -->
            <if test="fileType != null and fileType != ''">
                AND file_type IN (
                    <choose>
                        <when test="fileType == 'image'">'jpg','jpeg','png','gif','bmp','webp','svg'</when>
                        <when test="fileType == 'document'">'pdf','doc','docx','xls','xlsx','ppt','pptx'</when>
                        <when test="fileType == 'video'">'mp4','avi','mov','wmv','flv','mkv','webm'</when>
                        <when test="fileType == 'audio'">'mp3','wav','flac','aac','ogg','wma'</when>
                        <when test="fileType == 'archive'">'zip','rar','7z','tar','gz','bz2'</when>
                        <when test="fileType == 'other'">'txt','md','json','xml','csv','log','js','ts','html','css'</when>
                        <otherwise>''</otherwise>
                    </choose>
                )
            </if>
        </where>
        ORDER BY
            <choose>
                <when test="sortField == 'fileName'">file_name</when>
                <when test="sortField == 'fileSize'">file_size</when>
                <otherwise>upload_time</otherwise>
            </choose>
            <choose>
                <when test="sortOrder == 'asc'">ASC</when>
                <otherwise>DESC</otherwise>
            </choose>
    </select>

    <!-- 统计房间文件数量 -->
    <select id="countByRoomId" resultType="long">
        SELECT COUNT(*)
        FROM room_file
        WHERE room_id = #{roomId}
    </select>

    <!-- 统计房间文件总大小（含原图 + 缩略图） -->
    <select id="sumFileSizeByRoomId" resultType="long">
        SELECT IFNULL(SUM(file_size), 0) + IFNULL(SUM(thumbnail_size), 0)
        FROM room_file
        WHERE room_id = #{roomId}
    </select>

    <!-- 分批查询房间文件（用于清理时防止 OOM） -->
    <select id="selectBatchByRoomId" resultMap="RoomFileResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM room_file
        WHERE room_id = #{roomId}
        LIMIT #{limit}
    </select>

    <!-- 批量删除文件记录（替代 BaseMapper 的 deprecated deleteBatchIds） -->
    <delete id="deleteByIds">
        DELETE FROM room_file WHERE file_id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 原子递增下载计数（防止并发 Lost Update） -->
    <update id="incrementDownloadCount">
        UPDATE room_file
        SET download_count = download_count + 1
        WHERE file_id = #{fileId}
    </update>

</mapper>
